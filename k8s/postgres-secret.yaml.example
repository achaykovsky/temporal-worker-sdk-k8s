# Example only — do not commit real credentials. Copy to a local file (untracked) or use:
#   kubectl -n temporal create secret generic postgres-credentials \
#     --from-literal=POSTGRES_USER=temporal \
#     --from-literal=POSTGRES_PASSWORD='your-secure-password'
#
# Keys must match k8s/postgres.yaml and k8s/temporal.yaml (POSTGRES_PASSWORD feeds POSTGRES_PWD for Temporal).

apiVersion: v1
kind: Secret
metadata:
  name: postgres-credentials
  namespace: temporal
type: Opaque
stringData:
  POSTGRES_USER: temporal
  POSTGRES_PASSWORD: CHANGE_ME_BEFORE_APPLY
